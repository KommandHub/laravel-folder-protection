{
  "name": "kommandhub/laravel-folder-protection",
  "description": "A Laravel package for basic folder protection using basic auth, specifically for staging environments.",
  "type": "library",
  "license": "MIT",
  "authors": [
    {
      "name": "KommandHub",
      "email": "info@kommandhub.com"
    }
  ],
  "keywords": [
    "kommandhub",
    "php",
    "github",
    "laravel",
    "Open Source",
    "developer-tools"
  ],
  "require": {
    "php": "^8.2",
    "illuminate/support": "^11.0|^12.0",
    "illuminate/http": "^11.0|^12.0",
    "symfony/http-foundation": "^7.0"
  },
  "require-dev": {
    "laravel/pint": "^1.24",
    "orchestra/testbench": "^9.0|^10.0",
    "phpunit/phpunit": "^11.0"
  },
  "autoload": {
    "psr-4": {
      "KommandHub\\FolderProtection\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "KommandHub\\FolderProtection\\Tests\\": "tests/"
    }
  },
  "extra": {
    "laravel": {
      "providers": [
        "KommandHub\\FolderProtection\\FolderProtectionServiceProvider"
      ]
    }
  },
  "scripts": {
    "lint": "vendor/bin/pint --parallel",
    "test:lint": "vendor/bin/pint --parallel --test",
    "test": "vendor/bin/phpunit",
    "test:coverage": "vendor/bin/phpunit --coverage-text --coverage-html build/coverage",
    "test:coverage:pcov": "php -d pcov.enabled=1 vendor/bin/phpunit --coverage-text --coverage-html build/coverage"
  }
}